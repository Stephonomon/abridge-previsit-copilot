{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build --workspace web",
  "outputDirectory": "web/dist",
  "installCommand": "npm install",
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/data/**",
      "maxDuration": 120
    }
  }
}
