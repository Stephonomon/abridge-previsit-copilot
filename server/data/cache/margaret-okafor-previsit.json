                    "ref": "med-mo-warfarin",
                    "label": "Warfarin for mechanical MV"
                  }
                ]
              }
            ]
          },
          {
            "id": "meds",
            "title": "Meds That Matter Now",
            "items": [
              {
                "text": "Warfarin 5mg daily (2.5mg Sun) for mechanical MV — last INR 2.7 (7/10), no current INR; bleeding risk assessment pending, cardiology input needed before any hold/reversal",
                "severity": "caution",
                "sources": [
                  {
                    "ref": "lab-mo-inr-0710",
                    "label": "INR 7/10/2026"
                  },
                  {
                    "ref": "med-mo-warfarin",
                    "label": "Warfarin for mechanical MV"
                  }
                ]
              },
              {
                "text": "TMP-SMX allergy (Stevens-Johnson syndrome) — absolute avoidance; also resistant per prior culture",
                "severity": "act",
                "sources": [
                  {
                    "ref": "allergy-mo-smx",
                    "label": "TMP-SMX allergy (SJS)"
                  }
                ]
              },
              {
                "text": "Empagliflozin (SGLT2i) 10mg daily — hold during acute illness, risk of euglycemic DKA if septic/decompensating",
                "severity": "caution",
