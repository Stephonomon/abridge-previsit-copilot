                    "ref": "med-mo-empagliflozin",
                    "label": "Empagliflozin 10mg daily"
                  }
                ]
              },
              {
                "text": "Insulin glargine 18u nightly — hypoglycemia risk if oral intake drops with acute illness; monitor glucose closely",
                "severity": "caution",
                "sources": [
                  {
                    "ref": "med-mo-glargine",
                    "label": "Insulin glargine 18u nightly"
                  }
