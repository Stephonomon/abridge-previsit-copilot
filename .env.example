# Copy this file to .env in the repo root and fill in your key.
# Only required if you want to run agents live (PREVISIT_MODE=live) or
# re-record the replay cache (npm run warm --workspace server).
# The app ships with a pre-recorded cache and runs fully offline without this.
ANTHROPIC_API_KEY=

# --- Optional overrides (defaults shown) ---

# Anthropic model used by the sub-agents and synthesis calls.
# PREVISIT_MODEL=claude-sonnet-5

# "cached" replays recorded runs with compressed pacing (fast, no API key needed).
# "live" always calls the Anthropic API (slower, costs tokens).
# PREVISIT_MODE=cached

# Replay pacing, in milliseconds, when PREVISIT_MODE=cached.
# PREVISIT_REPLAY_MS=11000
# PREVISIT_REPLAY_DELTA_MS=5500

# Reasoning effort for live runs.
# PREVISIT_SUBAGENT_EFFORT=low
# PREVISIT_SYNTHESIS_EFFORT=medium

# Server port.
# PORT=8787
